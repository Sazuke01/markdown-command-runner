{
  "version": "0.0.1",
  "name": "markdown-command-runner",
  "displayName": "Markdown Command Runner",
  "description": "Run terminal commands from Markdown code blocks and inline snippets.",
  "publisher": "Sazuke01",
  "author": {
    "name": "Sazuke01"
  },
  "homepage": "https://github.com/Sazuke01/markdown-command-runner",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Sazuke01/markdown-command-runner"
  },
  "bugs": "https://github.com/Sazuke01/markdown-command-runner/issues",
  "icon": "resources/icon-128x128.png",
  "engines": {
    "vscode": "^1.110.0"
  },
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "galleryBanner": {
    "color": "#e3f4ff",
    "theme": "light"
  },
  "browser": "./out/extension.js",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "markdown-command-runner.runCommand",
        "title": "Markdown Command Runner: Ejecutar",
        "icon": "./resources/icon-128x128.png"
      }
    ],
    "configuration": {
      "title": "Markdown Command Runner",
      "properties": {
        "markdown-command-runner.enableCodeLens": {
          "type": "boolean",
          "default": true,
          "description": "Habilitar botones CodeLens sobre bloques de código de terminal"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node ./out/test/runTest.js",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "build": "npm run compile"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.110.0",
    "@vscode/test-electron": "^2.5.2",
    "chai": "^6.2.2",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "mocha": "^11.7.5",
    "prettier": "^3.8.1",
    "tslib": "2.8.1",
    "typescript": "^6.0.2"
  },
  "lint-staged": {
    "*.{ts,json,jsonc,md,yaml}": "prettier --write --experimental-cli --cache"
  }
}
